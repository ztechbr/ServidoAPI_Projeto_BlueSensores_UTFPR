# Opção 1: URL completa
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/nome_do_banco

# Opção 2: variáveis separadas
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASSWORD=sua_senha

# REST (GET/POST /leituras): quando definido e não vazio, exige o mesmo valor no cabeçalho
# Authorization: Bearer <token> ou X-API-Key: <token>. Deixe vazio para desativar (ex.: dev local).
# O endpoint SOAP /soap não usa este token.
API_TOKEN=chavebasicaaqui

# SOAP — target namespace (URI em <xs:schema targetNamespace="..."/> no WSDL).
# Se você definir apenas SOAP_PUBLIC_URL abaixo e deixar SOAP_NAMESPACE vazio, o namespace
# vira automaticamente {scheme}://{host}/leituras (ex.: https://api-sensores.ztechnologies.io/leituras).
# Para forçar outro valor (ou manter o padrão UTFPR com endpoint público), defina SOAP_NAMESPACE.
# SOAP_NAMESPACE=

# SOAP — URL pública do endpoint (POST SOAP), ex.: https://api-sensores.ztechnologies.io/soap
# Fixa <soap:address location="..."/> no WSDL. Recomendado em produção / Docker / proxy.
# SOAP_PUBLIC_URL=
